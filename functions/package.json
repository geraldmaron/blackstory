{
  "name": "@repo/functions-discovery",
  "private": true,
  "version": "0.0.0",
  "description": "Firebase Functions v2 scheduled discovery dispatch (ADR-018). Research SA only; never publishes.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": ".deploy/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node --conditions development --import tsx src/local-invoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --conditions development --import tsx --test src/mode.test.ts src/timeout.test.ts src/kill-switch-env.test.ts src/run-discovery.test.ts",
    "lint": "echo 'lint: use root pnpm lint'"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "@repo/firebase": "workspace:*",
    "firebase-admin": "^14.2.0",
    "firebase-functions": "^7.3.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^26.1.1",
    "esbuild": "^0.25.8",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2"
  }
}
