# apps/admin local environment template (placeholders only)
# Copy to apps/admin/.env.local.
#
# Solo-operator access: Firebase email/password. Provision users in Firebase
# Authentication (Console / Admin SDK). No hardcoded email list in app code.
# Set ADMIN_AUTH_MODE=firebase (default). `allowlist` is a deprecated alias.
# Production uses ADMIN_AUTH_MODE=layered (IAP + Firebase) when wired.
#
# Supabase Auth cutover (ADR-020): set ADMIN_AUTH_MODE=supabase and
# NEXT_PUBLIC_ADMIN_AUTH_MODE=supabase. Provision operators in Supabase Auth with
# app_metadata.bb_role=admin|research|publication|security (never user_metadata).
# Operator must exist in Supabase before sign-in (e.g. scripts/create-supabase-admin-user.py).
#
# Sibling public site (operator handoff links in admin chrome/footer):
# NEXT_PUBLIC_SITE_URL=http://localhost:3048
# Optional local reminders (gitignored in .env.local — never commit):
# ADMIN_LOGIN_EMAIL=<firebase-auth-email>
# ADMIN_LOGIN_PASSWORD=<set locally>

NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
ADMIN_AUTH_MODE=firebase

# --- Admin data source (Postgres SoR cutover) ---
# ADMIN_DATA_SOURCE=firestore
# ADMIN_DATA_SOURCE=postgres
# When unset: postgres if DATABASE_URL or APP_DATABASE_URL is set, else firestore.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# APP_DATABASE_URL=
# DATABASE_SSL=true
# DATABASE_POOL_MAX=4

# --- Emulator (local) ---
FIREBASE_EMULATOR_MODE=1
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-repo
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-repo.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_ADMIN_APP_ID=1:332234323945:web:e1b31c78e32d95943bfd78
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR=1
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# --- Production (black-book-efaaf) ---
# Unset FIREBASE_EMULATOR_MODE. Use ADC / GOOGLE_APPLICATION_CREDENTIALS for Admin SDK.
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=black-book-efaaf
# NEXT_PUBLIC_FIREBASE_API_KEY=<web api key>
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=black-book-efaaf.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=black-book-efaaf.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=332234323945
# NEXT_PUBLIC_FIREBASE_ADMIN_APP_ID=1:332234323945:web:e1b31c78e32d95943bfd78
# APP_FIREBASE_ALLOW_PRODUCTION=1
# Required for verifyIdToken(checkRevoked) with local ADC user credentials:
# GOOGLE_CLOUD_QUOTA_PROJECT=black-book-efaaf
# Or once: gcloud auth application-default set-quota-project black-book-efaaf

# --- Supabase Auth (blackstory-app) ---
# ADMIN_AUTH_MODE=supabase
# NEXT_PUBLIC_ADMIN_AUTH_MODE=supabase
# SUPABASE_URL=https://twykhihqkcldpreuovay.supabase.co
# SUPABASE_ANON_KEY=<publishable anon key — never service_role>
# NEXT_PUBLIC_SUPABASE_URL=https://twykhihqkcldpreuovay.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<same publishable anon key>
# Provision operator in Supabase Auth with app_metadata.bb_role=admin before first login.
