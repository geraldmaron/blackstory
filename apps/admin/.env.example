# BlackStory admin local environment (placeholders only).
# Copy to apps/admin/.env.local and never commit credentials.

NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
ADMIN_AUTH_MODE=supabase
NEXT_PUBLIC_ADMIN_AUTH_MODE=supabase
ADMIN_DATA_SOURCE=postgres

# Canonical Supabase/Postgres ledger. Prefer a scoped pooler role in deployed environments.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# APP_DATABASE_URL=
# DATABASE_SSL=true
# DATABASE_POOL_MAX=4

# Supabase Auth. Browser code receives only the publishable/anon key, never service_role.
# SUPABASE_URL=https://twykhihqkcldpreuovay.supabase.co
# SUPABASE_ANON_KEY=<publishable key>
# NEXT_PUBLIC_SUPABASE_URL=https://twykhihqkcldpreuovay.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<same publishable key>

# Provision operators in Supabase Auth before sign-in and set authorization only in
# app_metadata.bb_role: admin|research|publication|security. Never authorize from user_metadata.

# Sibling public site used for operator handoff links.
# NEXT_PUBLIC_SITE_URL=http://localhost:3048

# Optional local-only sign-in reminder.
# ADMIN_LOGIN_EMAIL=<supabase-auth-email>
# ADMIN_LOGIN_PASSWORD=<set locally>

# Explicit release activation break-glass. Leave unset for normal admin work.
# APP_RELEASE_ALLOW_PRODUCTION=1
