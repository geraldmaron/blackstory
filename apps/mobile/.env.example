# apps/mobile local environment template (names + placeholders only)
#
# Copy to apps/mobile/.env.local (gitignored) for local `expo start` / prebuild.
# NEVER put real secret values here or in any committed file. Everything below
# is read by app.config.ts and validated at config-eval time (a bad value fails
# the build fast, by name).

# Which identity/build tier to run locally (development | preview | production).
# Defaults to development when unset so a fresh clone never targets production.
APP_VARIANT=development

# Public API origins (apps/api-public + submissions). Production MUST be https.
# Unset → https://api.blackbook.app. For a local device pointing at a LAN dev
# server, set an http:// LAN IP here (allowed for dev/preview, rejected for prod).
# API_BASE_URL=http://192.168.1.50:8787
# SUBMISSIONS_BASE_URL=http://192.168.1.50:8787

# Observability kill switch + perf-trace sample rate (MOB-018). Defaults on/10%.
# Dev-console reporting only — no Firebase SDK is linked.
# OBSERVABILITY_ENABLED=true
# PERFORMANCE_SAMPLE_RATE=0.1

# EAS Update project id (non-secret identifier; gates updates.url + extra.eas.projectId
# in app.config.ts). Unset today — no Expo/EAS org provisioned yet (mobile-identity.md
# human gate #3). Set per EAS profile env / CI once eas init completes.
# EAS_PROJECT_ID=
