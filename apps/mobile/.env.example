# apps/mobile local environment template (names + placeholders only)
#
# Copy to apps/mobile/.env.local (gitignored) for local `expo start` / prebuild.
# NEVER put real secret values here or in any committed file. Everything below
# is read by app.config.ts and validated at config-eval time (a bad value fails
# the build fast, by name).

# Which identity/build tier to run locally (development | preview | production).
# Defaults to development when unset so a fresh clone never targets production.
APP_VARIANT=development

# Public API origins (apps/api-public + submissions). Production MUST be https.
# Unset → https://api.blackbook.app (intended prod host; requires DNS + Cloud Run
# deploy — as of 2026-07-22 api.blackbook.app is NXDOMAIN and black-book-api-public
# is not deployed, so Dev will fail bootstrap/search/entity until you point here).
#
# Local device / simulator against a LAN api-public (Postgres/Supabase reads):
#   Terminal A: cd apps/api-public && run-with-dev-secrets -- env \
#     PUBLIC_DATA_SOURCE=postgres DATABASE_SSL=1 pnpm dev   # :8080
#   Then set API_BASE_URL to the Mac's LAN IP (NOT localhost on a physical device):
# API_BASE_URL=http://192.168.1.50:8080
# SUBMISSIONS_BASE_URL=http://192.168.1.50:8080
#
# iOS Simulator may use http://127.0.0.1:8080.
# API_BASE_URL=http://127.0.0.1:8080

# Observability kill switch + perf-trace sample rate (MOB-018). Defaults on/10%.
# Dev-console reporting only — no Firebase SDK is linked.
# OBSERVABILITY_ENABLED=true
# PERFORMANCE_SAMPLE_RATE=0.1

# EAS Update project id (non-secret identifier; gates updates.url + extra.eas.projectId
# in app.config.ts). Set for local eval; also present in eas.json per-profile env.
# Expo account: geraldmaron · project: 51a35884-e6b5-43b6-b95b-c5a7460fa665
EAS_PROJECT_ID=51a35884-e6b5-43b6-b95b-c5a7460fa665
