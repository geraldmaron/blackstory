# apps/mobile local environment template (names + placeholders only)
#
# Copy to apps/mobile/.env.local (gitignored) for local `expo start` / prebuild.
# NEVER put real secret values here or in any committed file. Real Firebase
# native config comes from gitignored files or EAS file secrets — see README
# "Firebase & EAS secret wiring". Everything below is read by app.config.ts and
# validated at config-eval time (a bad value fails the build fast, by name).
#
# NONE of these are credentials: apiBaseUrl and firebase.projectId are public
# identifiers; the only real secret in mobile is the GoogleService file itself,
# which is a file path here, not an inline value.

# Which identity/build tier to run locally (development | preview | production).
# Defaults to development when unset so a fresh clone never targets production.
APP_VARIANT=development

# Public API origins (apps/api-public + submissions). Production MUST be https.
# Unset → https://api.blackbook.app. For a local device pointing at a LAN dev
# server, set an http:// LAN IP here (allowed for dev/preview, rejected for prod).
# API_BASE_URL=http://192.168.1.50:8787
# SUBMISSIONS_BASE_URL=http://192.168.1.50:8787

# App Check client-advisory enforcement stage (monitor | enforce). Defaults to
# monitor; only promote to enforce via the runbook in src/security/README.md.
# APP_CHECK_ENFORCEMENT_MODE=monitor

# Observability kill switch + perf-trace sample rate (MOB-018). Defaults on/10%.
# OBSERVABILITY_ENABLED=true
# PERFORMANCE_SAMPLE_RATE=0.1

# Public Firebase project id (non-secret; see infra/firebase/registered-apps.json).
# Defaults to black-book-efaaf.
# FIREBASE_PROJECT_ID=black-book-efaaf

# Firebase native config file PATHS (NOT the file contents). Set BOTH or NEITHER.
# When set, app.config.ts activates the @react-native-firebase/* config plugins
# so App Check / Crashlytics / Perf link into the native build. The files
# themselves are gitignored and must never be committed. For local dev, drop the
# real files under apps/mobile/secrets/ (gitignored) and point these at them;
# for EAS builds these paths are provided by `eas env:create --type file`.
# GOOGLE_SERVICES_INFO_PLIST=./secrets/GoogleService-Info.plist
# GOOGLE_SERVICES_JSON=./secrets/google-services.json

# EAS Update project id (non-secret identifier; gates updates.url + extra.eas.projectId
# in app.config.ts). Unset today — no Expo/EAS org provisioned yet (mobile-identity.md
# human gate #3). Set per EAS profile env / CI once eas init completes.
# EAS_PROJECT_ID=
