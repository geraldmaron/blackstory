    "eas-build:preview": "npx eas-cli build --profile preview",
    "eas-build:production": "npx eas-cli build --profile production",
    "eas-build-post-install": "npm install --prefix ../../packages/public-contracts --omit=dev --no-package-lock --ignore-scripts && npx tsc -p ../../packages/public-contracts/tsconfig.json"
