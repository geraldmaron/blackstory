{
  "name": "@repo/data-access",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "browser": "./src/browser-denied.ts",
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --conditions development --import tsx --test src/index.test.ts src/firestore.test.ts src/sql-static.test.ts src/postgres/data-source.test.ts",
    "test:integration": "node --conditions development --import tsx --test src/postgres.integration.test.ts",
    "lint": "echo 'lint: use root pnpm lint'"
  },
  "dependencies": {
    "@repo/domain": "workspace:*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.4",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
