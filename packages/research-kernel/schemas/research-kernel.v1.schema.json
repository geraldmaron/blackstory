        "profileVersion": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 },
        "mode": {
          "enum": [
            "deterministic",
            "local-triage",
            "free-batch",
            "paid-research",
            "quality-prose",
            "independent-review",
            "trusted-session"
          ]
