        "profile": { "$ref": "#/$defs/ResearchProfile" },
        "entities": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "activities": { "type": "array", "items": { "$ref": "#/$defs/AgentActivity" } },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/Artifact" } },
        "checksums": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 32 }
        }
      }
    }
