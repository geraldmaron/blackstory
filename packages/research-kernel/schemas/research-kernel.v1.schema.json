        "producerActivityId": { "type": "string", "minLength": 1 },
        "reviewDecisionIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "approvalLineageComplete": { "type": "boolean" },
        "status": {
          "enum": [
            "draft",
            "auditReady",
            "awaitingApproval",
            "approved",
            "rejected",
            "released",
            "retracted"
          ]
        }
      }
