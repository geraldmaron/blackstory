{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://black-book.local/schemas/promotion/promotion-record.v1.schema.json",
  "title": "BlackStory Promotion Record",
  "description": "Explicit state record from submission or discovery through publication release.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "stage", "submissionOrDiscoveryId", "updatedAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "stage": {
      "enum": [
        "submission_discovery",
        "research_case",
        "proposed_claim",
        "accepted_claim",
        "publication_candidate",
        "release"
      ]
    },
    "submissionOrDiscoveryId": { "type": "string", "minLength": 1 },
    "researchCaseId": { "type": "string", "minLength": 1 },
    "claimId": { "type": "string", "minLength": 1 },
    "releaseCandidateId": { "type": "string", "minLength": 1 },
    "releaseId": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "stage": {
            "enum": [
              "research_case",
              "proposed_claim",
              "accepted_claim",
              "publication_candidate",
              "release"
            ]
          }
        }
      },
      "then": { "required": ["researchCaseId"] }
    },
    {
      "if": {
        "properties": {
          "stage": {
            "enum": ["proposed_claim", "accepted_claim", "publication_candidate", "release"]
          }
        }
      },
      "then": { "required": ["claimId"] }
    },
    {
      "if": {
        "properties": {
          "stage": { "enum": ["publication_candidate", "release"] }
        }
      },
      "then": { "required": ["releaseCandidateId"] }
    },
    {
      "if": {
        "properties": { "stage": { "const": "release" } }
      },
      "then": { "required": ["releaseId"] }
    }
  ]
}
