{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://black-book.local/schemas/promotion/promotion-policy.v1.schema.json",
  "title": "Black Book Promotion Policy",
  "description": "Deterministic evidence and confidence requirements for claim promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyVersion",
    "minimumReputation",
    "standardMinimumIndependentLineages",
    "highImpactMinimumIndependentLineages",
    "highImpactMinimumStrongLineages",
    "standardConfidenceThreshold",
    "highImpactConfidenceThreshold",
    "strongReputations"
  ],
  "properties": {
    "policyVersion": { "type": "string", "minLength": 1 },
    "minimumReputation": {
      "enum": ["unknown", "limited", "established", "authoritative"]
    },
    "standardMinimumIndependentLineages": { "type": "integer", "minimum": 2 },
    "highImpactMinimumIndependentLineages": { "type": "integer", "minimum": 3 },
    "highImpactMinimumStrongLineages": { "type": "integer", "minimum": 2 },
    "standardConfidenceThreshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "highImpactConfidenceThreshold": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "strongReputations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["established", "authoritative"]
      }
    }
  }
}
