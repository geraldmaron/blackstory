{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/adapters/federal/nps-export.v1.schema.json",
  "title": "NpsNationalRegisterExportRecord",
  "description": "Fixture-only NPS / National Register export shape for federal adapter ingestion.",
  "type": "object",
  "additionalProperties": true,
  "required": ["stableIdentifier", "title"],
  "properties": {
    "stableIdentifier": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "canonicalUrl": { "type": "string", "format": "uri" },
    "classification": { "type": "string" },
    "nrhpReference": { "type": "string" },
    "state": { "type": "string", "minLength": 2, "maxLength": 2 },
    "locality": { "type": "string" }
  }
}
