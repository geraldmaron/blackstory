{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/adapters/federal/nara-export.v1.schema.json",
  "title": "NationalArchivesExportRecord",
  "description": "Fixture-only NARA catalog export shape for federal adapter ingestion (BB-046).",
  "type": "object",
  "additionalProperties": true,
  "required": ["title"],
  "properties": {
    "stableIdentifier": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "canonicalUrl": { "type": "string", "format": "uri" },
    "classification": { "type": "string" },
    "recordGroup": { "type": "string" },
    "series": { "type": "string" }
  }
}
