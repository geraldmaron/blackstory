{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/adapters/federal/school-history-export.v1.schema.json",
  "title": "SchoolHistoryExportRecord",
  "description": "Fixture-only approved structured school-history export shape (BB-046).",
  "type": "object",
  "additionalProperties": true,
  "required": ["stableIdentifier", "title", "curriculumTier"],
  "properties": {
    "stableIdentifier": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "canonicalUrl": { "type": "string", "format": "uri" },
    "classification": { "type": "string" },
    "curriculumTier": { "type": "string", "minLength": 1 },
    "gradeBand": { "type": "string" },
    "publisher": { "type": "string" }
  }
}
