{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/gold-corpus/gold-predictions.v1.schema.json",
  "title": "BlackStory Gold Predictions",
  "description": "A complete algorithm prediction set for one version of the gold corpus.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "algorithmVersion",
    "corpusVersion",
    "generatedAt",
    "predictions"
  ],
  "properties": {
    "schemaVersion": { "const": "gold-predictions.v1" },
    "algorithmVersion": { "type": "string", "minLength": 1 },
    "corpusVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "predictions": {
      "type": "array",
      "minItems": 100,
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "exampleId",
          "relevance",
          "publish",
          "confidence",
          "citationEntailed",
          "entityResolution"
        ],
        "properties": {
          "exampleId": { "type": "string", "pattern": "^gc-[0-9]{3}$" },
          "relevance": { "enum": ["include", "exclude", "supporting_context"] },
          "publish": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "citationEntailed": { "type": "boolean" },
          "entityResolution": { "enum": ["match", "no_match", "review_required"] },
          "resolvedEntityId": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
