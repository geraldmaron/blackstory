{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/gold-corpus/gold-evaluation.v1.schema.json",
  "title": "Black Book Gold Evaluation",
  "description": "Machine-readable evidence that an algorithm version passed corpus thresholds.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "corpusVersion",
    "algorithmVersion",
    "evaluatedAt",
    "passed",
    "thresholds",
    "metrics",
    "failures"
  ],
  "properties": {
    "schemaVersion": { "const": "gold-evaluation.v1" },
    "corpusVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "algorithmVersion": { "type": "string", "minLength": 1 },
    "evaluatedAt": { "type": "string", "format": "date-time" },
    "passed": { "type": "boolean" },
    "thresholds": { "$ref": "#/$defs/thresholds" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "failures": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "unit": { "type": "number", "minimum": 0, "maximum": 1 },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumPrecision",
        "minimumRecall",
        "maximumFalsePublicationRate",
        "maximumBrierScore",
        "maximumExpectedCalibrationError",
        "minimumCitationEntailmentAccuracy",
        "minimumEntityResolutionAccuracy"
      ],
      "properties": {
        "minimumPrecision": { "$ref": "#/$defs/unit" },
        "minimumRecall": { "$ref": "#/$defs/unit" },
        "maximumFalsePublicationRate": { "$ref": "#/$defs/unit" },
        "maximumBrierScore": { "$ref": "#/$defs/unit" },
        "maximumExpectedCalibrationError": { "$ref": "#/$defs/unit" },
        "minimumCitationEntailmentAccuracy": { "$ref": "#/$defs/unit" },
        "minimumEntityResolutionAccuracy": { "$ref": "#/$defs/unit" }
      }
    },
    "binary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truePositive",
        "falsePositive",
        "trueNegative",
        "falseNegative",
        "precision",
        "recall"
      ],
      "properties": {
        "truePositive": { "type": "integer", "minimum": 0 },
        "falsePositive": { "type": "integer", "minimum": 0 },
        "trueNegative": { "type": "integer", "minimum": 0 },
        "falseNegative": { "type": "integer", "minimum": 0 },
        "precision": { "$ref": "#/$defs/unit" },
        "recall": { "$ref": "#/$defs/unit" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exampleCount",
        "relevance",
        "publication",
        "falsePublicationRate",
        "calibration",
        "citationEntailmentAccuracy",
        "entityResolutionAccuracy"
      ],
      "properties": {
        "exampleCount": { "type": "integer", "minimum": 100, "maximum": 200 },
        "relevance": { "$ref": "#/$defs/binary" },
        "publication": { "$ref": "#/$defs/binary" },
        "falsePublicationRate": { "$ref": "#/$defs/unit" },
        "calibration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["brierScore", "expectedCalibrationError", "bins"],
          "properties": {
            "brierScore": { "$ref": "#/$defs/unit" },
            "expectedCalibrationError": { "$ref": "#/$defs/unit" },
            "bins": { "type": "array", "minItems": 10, "maxItems": 10 }
          }
        },
        "citationEntailmentAccuracy": { "$ref": "#/$defs/unit" },
        "entityResolutionAccuracy": { "$ref": "#/$defs/unit" }
      }
    }
  }
}
