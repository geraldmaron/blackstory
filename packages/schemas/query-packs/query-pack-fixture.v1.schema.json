{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/query-packs/query-pack-fixture.v1.schema.json",
  "title": "QueryPackFixture",
  "description": "Query pack with expected match and exclusion expectations for gold tests.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pack", "expectations"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "query-pack.v1"
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "entityKind", "theme", "version", "terms", "createdAt"],
      "properties": {
        "schemaVersion": { "type": "string", "const": "query-pack.v1" },
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "entityKind": { "type": "string" },
        "theme": { "type": "string" },
        "version": {
          "type": "object",
          "required": ["semver"],
          "properties": {
            "semver": { "type": "string" },
            "contentHash": { "type": "string" }
          }
        },
        "terms": { "type": "array", "minItems": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["input", "shouldMatch"],
        "properties": {
          "input": { "type": "string", "minLength": 1 },
          "shouldMatch": { "type": "boolean" },
          "expectedOutcome": {
            "type": "string",
            "enum": ["promotable", "candidate_only"]
          },
          "matchedTermClasses": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
