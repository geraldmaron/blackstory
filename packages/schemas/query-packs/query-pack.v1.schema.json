{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackbook.local/schemas/query-packs/query-pack.v1.schema.json",
  "title": "QueryPack",
  "description": "Versioned historical query pack with term classes and content-hash identity (BB-038).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "entityKind",
    "theme",
    "version",
    "terms",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "query-pack.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "entityKind": {
      "type": "string",
      "enum": [
        "person",
        "place",
        "school",
        "organization",
        "institution",
        "event",
        "law",
        "case",
        "publication",
        "artifact",
        "other"
      ]
    },
    "theme": {
      "type": "string",
      "enum": [
        "civil_rights",
        "education_segregation",
        "archival_person",
        "historical_place",
        "institutional_records",
        "legal_case"
      ]
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semver", "contentHash"],
      "properties": {
        "semver": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
        },
        "contentHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "versionId": {
      "type": "string",
      "minLength": 1
    },
    "terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "termClass"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "termClass": {
            "type": "string",
            "enum": [
              "positive",
              "negative",
              "historical",
              "modern",
              "geographic",
              "alias",
              "source_specific"
            ]
          },
          "researchOnlyOffensive": { "type": "boolean" },
          "sourceId": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0 }
        },
        "if": {
          "properties": { "termClass": { "const": "source_specific" } },
          "required": ["termClass"]
        },
        "then": {
          "required": ["sourceId"]
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
