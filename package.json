{
  "name": "blackstory",
  "private": true,
  "version": "0.0.0",
  "description": "BlackStory — place-connected Black history research platform (monorepo; code scope @repo)",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bootstrap": "./scripts/bootstrap.sh",
    "build": "pnpm -r --filter './packages/**' --filter './apps/**' --filter @repo/functions-discovery run build",
    "apphosting:build": "pnpm --filter @repo/web... --workspace-concurrency=1 build",
    "start": "node apps/web/.next/standalone/apps/web/server.js",
    "test": "pnpm test:preflight && pnpm -r --filter './packages/**' --filter './apps/**' --filter @repo/functions-discovery run --if-present test && uv run pytest",
    "test:preflight": "node --import tsx scripts/test-preflight.mjs",
    "test:js": "pnpm test:preflight && pnpm -r --filter './packages/**' --filter './apps/**' --filter @repo/functions-discovery run --if-present test",
    "test:py": "pnpm test:preflight && uv run pytest",
    "test:unit": "pnpm test:preflight && pnpm --filter @repo/testing test:unit && pnpm -r --filter './packages/**' --filter './apps/**' --filter '!@repo/testing' run --if-present test && uv run pytest",
    "test:contract": "pnpm test:preflight && pnpm --filter @repo/testing test:contract",
    "test:security": "pnpm test:preflight && pnpm --filter @repo/testing test:security",
    "test:a11y": "pnpm test:preflight && pnpm --filter @repo/testing test:a11y",
    "test:integration": "pnpm test:preflight && pnpm --filter @repo/testing test:integration",
    "test:migration": "pnpm test:preflight && pnpm --filter @repo/testing test:migration",
    "test:e2e": "pnpm test:preflight && pnpm --filter @repo/testing test:e2e",
    "test:coverage": "pnpm test:preflight && pnpm --filter @repo/testing test:coverage",
    "typecheck": "pnpm -r --filter './packages/**' --filter './apps/**' --filter @repo/functions-discovery run --if-present typecheck",
    "lint": "eslint apps packages functions scripts eslint.config.mjs --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm validate:boundaries && pnpm lint && pnpm validate:governance",
    "validate:boundaries": "node scripts/validate-boundaries.mjs",
    "validate:governance": "node scripts/validate-github-governance.mjs",
    "firebase:emulators": "bash -lc 'export JAVA_HOME=\"${JAVA_HOME:-/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home}\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; FIREBASE_CLI_DISABLE_UPDATE_CHECK=true firebase emulators:start --project demo-repo --config infra/firebase/firebase.json'",
    "firebase:test:rules": "pnpm --filter @repo/firebase exec node --conditions development --import tsx --test src/rules.integration.test.ts",
    "db:up": "docker compose -f infra/database/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/database/docker-compose.yml down",
    "db:status": "docker compose -f infra/database/docker-compose.yml ps",
    "db:init": "bash infra/database/scripts/apply-init.sh",
    "db:verify": "bash infra/database/scripts/verify-isolation.sh",
    "db:sql-connect:compile": "FIREBASE_CLI_DISABLE_UPDATE_CHECK=true firebase dataconnect:compile -c infra/database/sql-connect/firebase.json",
    "db:sql-connect:sdk": "FIREBASE_CLI_DISABLE_UPDATE_CHECK=true firebase dataconnect:sdk:generate -c infra/database/sql-connect/firebase.json",
    "test:db:integration": "pnpm --filter @repo/data-access test:integration"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:^",
    "@repo/typescript-config": "workspace:^",
    "firebase-tools": "^15.24.0",
    "prettier": "^3.6.2",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  }
}
