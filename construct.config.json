// Construct project config — JSONC: comments and a trailing comma are allowed.
// Uncomment/edit a value to override its default; commented lines never take effect.
//
//   deployment.mode:      "solo" | "team" | "enterprise"
//   deployment.mcpBroker: "auto" | "on" | "off"
//   model tiers ("fast" | "standard" | "reasoning") are set via
//   `construct models set` / CX_MODEL_* env, not in this file.

{
  "version": 1,
  "alias": "Construct",
  "deployment": {
    "mode": "solo",
    "mcpBroker": "auto",
    "projectName": null,
    "tenantId": null
  },
  "providers": {},
  "sources": {
    "targets": []
  },
  "intakePolicy": {
    "maxDepth": 4,
    "additionalDirs": []
  },
  "artifactWorkflow": {
    "defaults": {},
    "types": {}
  },
  "scope": "rnd",
  "autoEmbed": false,
  "ingest": {
    "strategy": "adapter",
    "fallback": "none",
    "orchestration": "prompt-only"
  },
  "orchestration": {
    "workerBackend": "inline",
    "store": "filesystem",
    "chainOfThought": "hidden",
    "hostExecution": "auto",
    "outcomeRouting": "on"
  },
  "telemetry": {
    "enabled": true
  },
  "hooks": {
    "outputMode": "auto"
  },
  "models": {
    "visibility": {
      "mode": "tier_defaults",
      "include": [],
      "exclude": [],
      "providers": {}
    },
    "catalog": {
      "liveOpenRouter": true,
      "maxLiveFree": 24
    }
  },
  "resources": {
    "disk": {
      "tracesMaxDays": 30,
      "intakeArchiveMaxItems": 500,
      "intakeArchiveMaxDays": 90,
      "taskGraphsMaxItems": 200,
      "taskGraphsMaxDays": 90,
      "workerLogsMaxMb": 100,
      "workerLogsMaxDays": 14,
      "sessionsMaxItems": 100,
      "backupsMaxDays": 60,
      "handoffsMaxDays": 30,
      "handoffsMaxItems": 50,
      "totalCxMaxMb": 2000,
      "observationsMaxDays": 90,
      "observationsMaxRows": 5000
    },
    "process": {
      "embedDaemonMaxRssMb": 800,
      "mcpServerMaxRssMb": 250,
      "workerReplicaMaxRssMb": 256
    }
  },
  "$schema": "./node_modules/@geraldmaron/construct/schemas/project-config.schema.json"
}
