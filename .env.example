# Environment templates (names and placeholders only)
#
# Copy to `.env.local` (gitignored) for local Next.js. Local development must use
# Firebase emulators (`pnpm firebase:emulators`) with demo-repo — never point
# local clients at black-book-efaaf unless BLACK_BOOK_FIREBASE_ALLOW_PRODUCTION=1.
#
# Production secrets belong in Secret Manager and App Hosting `secret:` refs.
# Firebase client apiKey/appId values are public identifiers (see infra/firebase/).

# Runtime
NODE_ENV=development
LOG_LEVEL=info
BLACK_BOOK_ENV=development

# Local Firebase emulators (required for non-production Firebase usage)
FIREBASE_EMULATOR_MODE=1
FIREBASE_PROJECT_ID=demo-repo
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Public web client identifiers (emulator defaults are applied by @black-book/firebase
# when emulator hosts are set; production values live in infra/firebase/registered-apps.json)
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-repo
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-repo.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:332234323945:web:17be349ebc9c029b3bfd78
NEXT_PUBLIC_FIREBASE_ADMIN_APP_ID=1:332234323945:web:e1b31c78e32d95943bfd78

# App Check (BB-011 scaffold only — enforcement is BB-024)
# NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=replace-with-recaptcha-enterprise-site-key

# Server Admin SDK — leave unset for emulators. Never commit credential files.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc.json

# Embedding pipeline (BB-071 / ADR-014) — Gemini Developer API key for gemini-embedding-001.
# Production values belong in Secret Manager, never here. Tests/CI use the deterministic mock
# provider (@black-book/firebase's createDeterministicMockEmbeddingProvider) and need no key.
# GEMINI_API_KEY=replace-with-secret-manager-reference

# Optional overnight hybrid enrichment (OpenRouter free + Ollama on Corsair).
# OPENROUTER_API_KEY=op://…  (use run-with-dev-secrets locally; enrichment.env on Corsair)
# EDITORIAL_LLM_PROVIDER=hybrid
# OPENROUTER_MODEL=            # pin a single model (wins over the roster below)
# OPENROUTER_MODELS=tencent/hy3:free,nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-nano-30b-a3b:free,google/gemma-4-31b-it:free,openai/gpt-oss-20b:free,qwen/qwen3-235b-a22b-2507,mistralai/mistral-small-3.2-24b-instruct,qwen/qwen3-30b-a3b-instruct-2507,mistralai/mistral-nemo
# Free models tried first (cost $0); the last 4 are cheap paid fallbacks (~$0.05-$0.55/M
# tokens), ORDERED BY CAPABILITY not cost (qwen3-235b-a22b first — the editorial judge's
# relevance-judgment task needs real reasoning quality, not just the cheapest option),
# only reached when EVERY free model in the list fails for that specific request (e.g. a
# daily free-tier quota exhaustion, observed 2026-07-20). See
# docs/runbooks/gap-fill-research.md for real cost estimates per batch.
# OLLAMA_BASE_URL=http://100.119.72.84:11434/v1
# OLLAMA_MODEL=qwen3:8b
# TARGET_CANDIDATES=1000
# ENRICH_CONCURRENCY=4

# Self-hosted SearXNG (preferred OSS web-search discovery — Corsair via Tailscale).
# Live: SEARXNG_BASE_URL=http://100.119.72.84:8888 DISCOVERY_STORAGE_TERMS_CONFIRMED=true
# Inject: DISCOVERY_SEARXNG_JSON=/path/to/searxng-response.json
# Optional reverse-proxy token: SEARXNG_AUTH_TOKEN=...
# SEARXNG_BASE_URL=http://100.119.72.84:8888
# Query roster (default): packages/config/src/scheduled-jobs/data/corsair-web-search-queries.json
# DISCOVERY_SEARXNG_QUERY_FILE=/path/to/corsair-web-search-queries.json
# DISCOVERY_QUERIES_PER_RUN=3
# DISCOVERY_SEARXNG_QUERY=…   # optional single-query override (skips roster rotation)
# Overnight: SEARXNG_QUERIES_PER_NIGHT=8 SKIP_SEARXNG=0
# DISCOVERY_STORAGE_TERMS_CONFIRMED=true

# Community discovery adapters (BB-073) — free DPLA v2 API key (api.dp.la/v2).
# Production values belong in Secret Manager, never here. Tests/CI use a deterministic fake key
# with a mocked SafeHttpClient (packages/domain/src/adapters/dpla) and need no real key.
# DPLA_API_KEY=replace-with-secret-manager-reference

# Optional Brave fallback (only if DISCOVERY_WEB_SEARCH_PROVIDER=brave).
# BRAVE_SEARCH_API_KEY=replace-with-secret-manager-reference

# Census data API (black-book-vxz) — free api.census.gov key, caller-supplied to the
# @repo/domain census-demographics adapters (never read inside the adapter; DPLA pattern).
# Local: op read "op://Private/USCensus/credential" >> .env.local as CENSUS_API_KEY=...
# Production: Secret Manager secret `census-api-key`, never here. Provenance sourceUrl is
# always the keyless form (buildProvenanceSourceUrl) — the key must never be persisted.
# CENSUS_API_KEY=replace-with-secret-manager-reference

# Production break-glass (do not set for routine local work)
# BLACK_BOOK_FIREBASE_ALLOW_PRODUCTION=1

# Local PostGIS (not a secret for disposable local compose)
DATABASE_URL=postgresql://blackbook:blackbook@localhost:5432/blackbook
BLACK_BOOK_DB_ROLE=role_public_read
# DATABASE_POOL_MAX=10
# DATABASE_POOL_ACQUIRE_TIMEOUT_MS=2000

# Never set NEXT_PUBLIC_* database URLs — browsers must not receive DB credentials.
# NEXT_PUBLIC_DATABASE_URL=  # FORBIDDEN
