infra/database/data/

# SQL Connect local emulator / generated SDK churn
infra/database/sql-connect/dataconnect/.dataconnect/
packages/data-access/generated/*/
!packages/data-access/generated/README.md

# .claude/ — machine-local Claude Code config (hooks, launch config, synced
# skill libraries). Never source, except the carve-out below.
.claude/*
# Exception: Black Book product skills (BB-085) are committed source — thin
# callers over tested @repo/* packages.
# (A gitignored parent dir can't be re-included by a child negation, so this
# un-ignores .claude/ contents one level at a time down to the carve-out.)
!.claude/skills/
.claude/skills/*
!.claude/skills/black-book/
.codex/
.cursor/
.vscode/
.opencode/
.mcp.json
.github/prompts/
.github/agents/
.vercel/
config.env
embed.yaml
plan.md
# Operator/local drop folders at repo root only — do not ignore apps/admin/src/app/inbox
/inbox/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
