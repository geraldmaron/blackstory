# Docker volumes
infra/database/data/

# SQL Connect local emulator / generated SDK churn
infra/database/sql-connect/dataconnect/.dataconnect/
packages/data-access/generated/*/
!packages/data-access/generated/README.md

# Construct — generated adapters, launcher, and runtime state.
# Machine-specific, recreated by `construct sync`; never source (ADR-0027).
.construct/
.claude/*
# Exception: Black Book product skills (BB-085) are committed source — thin
# callers over tested @black-book/* packages, not Construct-generated state.
# (A gitignored parent dir can't be re-included by a child negation, so this
# un-ignores .claude/ contents one level at a time down to the carve-out.)
!.claude/skills/
.claude/skills/*
!.claude/skills/black-book/
.codex/
.cursor/
.vscode/
.opencode/
.mcp.json
.github/prompts/
.github/agents/
config.env
embed.yaml
plan.md
inbox/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
