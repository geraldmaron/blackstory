{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Black Book security alert policies (BB-034)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "status", "projectId", "bead", "policies"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "1.0.0" },
    "status": { "const": "design-only" },
    "projectId": { "const": "black-book-efaaf" },
    "bead": { "const": "BB-034" },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "severity",
          "runbookId",
          "description",
          "notificationChannels",
          "metric",
          "windowMs",
          "threshold",
          "comparator",
          "immediateNotification",
          "enabled"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^SEC-" },
          "kind": { "type": "string" },
          "severity": { "enum": ["info", "warning", "critical"] },
          "runbookId": { "type": "string", "pattern": "^runbook/" },
          "description": { "type": "string", "minLength": 1 },
          "notificationChannels": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["pager", "security_alerts", "ops", "email"] }
          },
          "metric": { "type": "string" },
          "windowMs": { "type": "integer", "minimum": 1000 },
          "threshold": { "type": "number" },
          "comparator": { "enum": ["gt", "gte", "lt", "lte"] },
          "immediateNotification": { "type": "boolean" },
          "enabled": { "const": true }
        }
      }
    }
  }
}
