{
  "version": "1.0.0",
  "status": "design-only",
  "principals": [
    {
      "id": "web-runtime",
      "scope": "public snapshot and public API reads",
      "revokeIndependently": true,
      "containmentFallback": "public-static-mode"
    },
    {
      "id": "api-public",
      "scope": "public projection, search, and location reads",
      "revokeIndependently": true,
      "containmentFallback": "public-static-mode"
    },
    {
      "id": "api-submissions",
      "scope": "quarantine and submission metadata writes",
      "revokeIndependently": true,
      "containmentFallback": "corrections-submissions"
    },
    {
      "id": "api-internal",
      "scope": "canonical writes and publication",
      "revokeIndependently": true,
      "containmentFallback": "publication"
    },
    {
      "id": "admin",
      "scope": "research and publication review",
      "revokeIndependently": true,
      "containmentFallback": "publication"
    },
    {
      "id": "publication-signing-key",
      "scope": "release-manifest signing",
      "revokeIndependently": true,
      "containmentFallback": "publication"
    },
    {
      "id": "geocoder-provider",
      "scope": "external geocoding",
      "revokeIndependently": true,
      "containmentFallback": "geocoding"
    },
    {
      "id": "llm-provider",
      "scope": "model inference",
      "revokeIndependently": true,
      "containmentFallback": "llm-calls"
    }
  ],
  "rules": [
    "Disable or remove only the compromised principal binding; do not rotate unrelated identities.",
    "Engage the matching kill switch before revocation when active abuse could continue.",
    "Invalidate sessions or provider keys, inspect audit logs, then issue a replacement with least privilege.",
    "Never place replacement credentials in this repository."
  ]
}
