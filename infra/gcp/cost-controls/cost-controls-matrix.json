{
  "$schema": "./cost-controls.schema.json",
  "version": "1.0.0",
  "bead": "BB-033",
  "title": "Black Book cost and resource exhaustion controls",
  "updatedAt": "2026-07-17",
  "status": "design",
  "projectId": "black-book-efaaf",
  "region": "us-central1",
  "dependencyRefs": ["BB-022", "BB-023", "BB-025"],
  "policyPackageRef": "packages/security/src/resource-controls.ts",
  "notes": [
    "Declarative stubs only — not applied to live GCP. Apply via Terraform or gcloud after review.",
    "App Hosting maxInstances/concurrency authoritative values remain in apps/web/apphosting*.yaml (BB-022).",
    "Endpoint rate quotas remain in packages/security/src/rate-limits.ts (BB-025).",
    "Public historical corpus is never auto-disabled unless an operator explicitly chooses hard-stop.",
    "Billing export configuration references Cloud Billing Budget API — no secrets in this repo."
  ],
  "services": [
    {
      "id": "web",
      "runtime": "firebase-app-hosting",
      "tier": "public_serving",
      "minInstances": 2,
      "maxInstances": 6,
      "concurrency": 40,
      "cpu": 1,
      "memoryMiB": 384,
      "bb022Ref": "apps/web/apphosting.production.yaml"
    },
    {
      "id": "api-public",
      "runtime": "cloud-run",
      "tier": "public_serving",
      "minInstances": 1,
      "maxInstances": 8,
      "concurrency": 80,
      "cpu": 1,
      "memoryMiB": 512
    },
    {
      "id": "api-submissions",
      "runtime": "cloud-run",
      "tier": "essential_ops",
      "minInstances": 0,
      "maxInstances": 4,
      "concurrency": 40,
      "cpu": 1,
      "memoryMiB": 512
    },
    {
      "id": "api-internal",
      "runtime": "cloud-run",
      "tier": "essential_ops",
      "minInstances": 0,
      "maxInstances": 3,
      "concurrency": 20,
      "cpu": 1,
      "memoryMiB": 512
    },
    {
      "id": "admin",
      "runtime": "cloud-run",
      "tier": "essential_ops",
      "minInstances": 0,
      "maxInstances": 2,
      "concurrency": 20,
      "cpu": 1,
      "memoryMiB": 512
    }
  ],
  "cloudTasksQueues": [
    {
      "id": "submissions-intake",
      "tier": "essential_ops",
      "maxDispatchesPerSecond": 10,
      "maxConcurrentDispatches": 20,
      "maxAttempts": 5,
      "retry": {
        "maxAttempts": 5,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "maxQueueDepth": 5000
    },
    {
      "id": "url-evaluation",
      "tier": "optional_research",
      "maxDispatchesPerSecond": 5,
      "maxConcurrentDispatches": 10,
      "maxAttempts": 4,
      "retry": {
        "maxAttempts": 4,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "maxQueueDepth": 2000
    },
    {
      "id": "publication-preview",
      "tier": "essential_ops",
      "maxDispatchesPerSecond": 2,
      "maxConcurrentDispatches": 4,
      "maxAttempts": 3,
      "retry": {
        "maxAttempts": 3,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 120000,
        "multiplier": 2
      },
      "maxQueueDepth": 500
    },
    {
      "id": "outbox-dispatch",
      "tier": "essential_ops",
      "maxDispatchesPerSecond": 20,
      "maxConcurrentDispatches": 30,
      "maxAttempts": 5,
      "retry": {
        "maxAttempts": 5,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "maxQueueDepth": 10000
    },
    {
      "id": "research-campaign",
      "tier": "optional_research",
      "maxDispatchesPerSecond": 1,
      "maxConcurrentDispatches": 2,
      "maxAttempts": 3,
      "retry": {
        "maxAttempts": 3,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "maxQueueDepth": 200
    }
  ],
  "cloudRunJobs": [
    {
      "id": "research-discovery",
      "tier": "optional_research",
      "cpu": 1,
      "memoryMiB": 1024,
      "maxDurationSec": 3600,
      "maxRetries": 2,
      "retry": {
        "maxAttempts": 3,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "taskCount": 1,
      "parallelism": 1
    },
    {
      "id": "research-campaign",
      "tier": "optional_research",
      "cpu": 2,
      "memoryMiB": 2048,
      "maxDurationSec": 14400,
      "maxRetries": 1,
      "retry": {
        "maxAttempts": 2,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 600000,
        "multiplier": 2
      },
      "taskCount": 1,
      "parallelism": 1
    },
    {
      "id": "publication-projection",
      "tier": "essential_ops",
      "cpu": 2,
      "memoryMiB": 2048,
      "maxDurationSec": 7200,
      "maxRetries": 2,
      "retry": {
        "maxAttempts": 3,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "taskCount": 1,
      "parallelism": 1
    },
    {
      "id": "publication-release",
      "tier": "essential_ops",
      "cpu": 1,
      "memoryMiB": 1024,
      "maxDurationSec": 1800,
      "maxRetries": 1,
      "retry": {
        "maxAttempts": 2,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "taskCount": 1,
      "parallelism": 1
    },
    {
      "id": "security-url-fetch",
      "tier": "optional_research",
      "cpu": 1,
      "memoryMiB": 512,
      "maxDurationSec": 300,
      "maxRetries": 2,
      "retry": {
        "maxAttempts": 3,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 60000,
        "multiplier": 2
      },
      "taskCount": 1,
      "parallelism": 1
    },
    {
      "id": "security-quarantine",
      "tier": "essential_ops",
      "cpu": 1,
      "memoryMiB": 512,
      "maxDurationSec": 600,
      "maxRetries": 2,
      "retry": {
        "maxAttempts": 3,
        "initialBackoffMs": 1000,
        "maxBackoffMs": 300000,
        "multiplier": 2
      },
      "taskCount": 1,
      "parallelism": 1
    }
  ],
  "databaseLimits": [
    {
      "role": "role_public_read",
      "maxConnections": 10,
      "statementTimeoutMs": 5000,
      "idleTransactionTimeoutMs": 30000,
      "lockTimeoutMs": 2000
    },
    {
      "role": "role_submissions",
      "maxConnections": 5,
      "statementTimeoutMs": 3000,
      "idleTransactionTimeoutMs": 15000,
      "lockTimeoutMs": 1000
    },
    {
      "role": "role_publication",
      "maxConnections": 8,
      "statementTimeoutMs": 30000,
      "idleTransactionTimeoutMs": 60000,
      "lockTimeoutMs": 5000
    },
    {
      "role": "role_research",
      "maxConnections": 4,
      "statementTimeoutMs": 60000,
      "idleTransactionTimeoutMs": 30000,
      "lockTimeoutMs": 3000
    }
  ],
  "dailyBudgets": [
    {
      "category": "geocoder",
      "dailyCap": 5000,
      "unit": "requests",
      "softShutdownAtPercent": 80,
      "hardStopAtPercent": 100,
      "automatedResponse": "disable_geocoder"
    },
    {
      "category": "model",
      "dailyCap": 500000,
      "unit": "tokens",
      "softShutdownAtPercent": 75,
      "hardStopAtPercent": 100,
      "automatedResponse": "disable_model"
    },
    {
      "category": "ocr",
      "dailyCap": 1000,
      "unit": "requests",
      "softShutdownAtPercent": 80,
      "hardStopAtPercent": 100,
      "automatedResponse": "throttle_optional"
    },
    {
      "category": "source_fetch",
      "dailyCap": 2000,
      "unit": "requests",
      "softShutdownAtPercent": 80,
      "hardStopAtPercent": 100,
      "automatedResponse": "disable_source_fetch"
    },
    {
      "category": "research_campaign",
      "dailyCap": 50,
      "unit": "requests",
      "softShutdownAtPercent": 70,
      "hardStopAtPercent": 100,
      "automatedResponse": "pause_research"
    }
  ],
  "researchCampaignBudget": {
    "maxCandidatesPerRun": 500,
    "maxConcurrentAdapters": 2,
    "maxDailyRuns": 10,
    "maxWallClockSec": 14400,
    "maxEgressBytes": 536870912
  },
  "billingAlerts": [
    {
      "alertId": "budget-50-warning",
      "thresholdPercent": 50,
      "automatedResponse": "alert_only",
      "notifyChannels": ["email"],
      "runbookRef": "infra/gcp/cost-controls/hard-stop-runbook.md"
    },
    {
      "alertId": "budget-80-soft-shutdown",
      "thresholdPercent": 80,
      "automatedResponse": "throttle_optional",
      "notifyChannels": ["email", "slack"],
      "runbookRef": "infra/gcp/cost-controls/hard-stop-runbook.md"
    },
    {
      "alertId": "budget-95-pause-research",
      "thresholdPercent": 95,
      "automatedResponse": "pause_research",
      "notifyChannels": ["email", "slack", "pagerduty"],
      "runbookRef": "infra/gcp/cost-controls/hard-stop-runbook.md"
    },
    {
      "alertId": "budget-100-hard-stop-optional",
      "thresholdPercent": 100,
      "automatedResponse": "pause_research",
      "notifyChannels": ["email", "slack", "pagerduty"],
      "runbookRef": "infra/gcp/cost-controls/hard-stop-runbook.md"
    }
  ],
  "softShutdown": {
    "autoDisablePublicCorpus": false,
    "shutdownOrder": ["optional_research", "essential_ops"],
    "preserveTiers": ["public_serving"]
  },
  "acceptanceCriteria": [
    {
      "id": "AC-COST-1",
      "criterion": "Traffic spike cannot scale every service without bound",
      "enforcedBy": [
        "packages/security/src/resource-controls.ts DEFAULT_SERVICE_SCALING_LIMITS",
        "infra/gcp/cost-controls/cost-controls-matrix.json services[].maxInstances",
        "apps/web/apphosting*.yaml runConfig.maxInstances (BB-022)"
      ]
    },
    {
      "id": "AC-COST-2",
      "criterion": "Retries have capped exponential backoff and maximum attempts",
      "enforcedBy": [
        "packages/security/src/resource-controls.ts computeRetryDelay + assertRetryPoliciesBounded",
        "infra/gcp/cost-controls/cost-controls-matrix.json cloudTasksQueues[].retry"
      ]
    },
    {
      "id": "AC-COST-3",
      "criterion": "Optional research stops before public serving",
      "enforcedBy": [
        "packages/security/src/resource-controls.ts evaluateSoftShutdown",
        "softShutdown.shutdownOrder optional_research before essential_ops",
        "softShutdown.autoDisablePublicCorpus false"
      ]
    },
    {
      "id": "AC-COST-4",
      "criterion": "Budget alerts paired with concrete automated responses",
      "enforcedBy": [
        "packages/security/src/resource-controls.ts evaluateDailyBudget + DEFAULT_BILLING_ALERTS",
        "infra/gcp/cost-controls/cost-controls-matrix.json billingAlerts"
      ]
    },
    {
      "id": "AC-COST-5",
      "criterion": "Cost-control tests simulate abusive traffic pattern",
      "enforcedBy": [
        "packages/security/src/resource-controls.test.ts simulateAbusiveTrafficPattern",
        "infra/gcp/cost-controls/cost-controls.test.mjs"
      ]
    }
  ]
}
