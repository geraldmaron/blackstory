{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Black Book scheduled-job Cloud Scheduler mirror (BB-084)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "status", "bead", "environment", "policyPackageRef", "jobs"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "1.0.0" },
    "status": { "const": "design" },
    "bead": { "const": "BB-084" },
    "environment": { "const": "blackbook-internal" },
    "policyPackageRef": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "owner",
          "cronExpression",
          "humanReadable",
          "budget",
          "timeoutSec",
          "idempotencyKeyScheme",
          "killSwitchId",
          "targetWorker",
          "publicEffect",
          "rosterStatus"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,127}$" },
          "owner": { "type": "string", "minLength": 1 },
          "cronExpression": { "type": "string", "minLength": 1 },
          "humanReadable": { "type": "string", "minLength": 1 },
          "budget": {
            "type": "object",
            "additionalProperties": false,
            "required": ["unit", "maxPerRun"],
            "properties": {
              "unit": { "type": "string", "minLength": 1 },
              "maxPerRun": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "timeoutSec": { "type": "integer", "minimum": 1, "maximum": 86400 },
          "idempotencyKeyScheme": { "type": "string", "pattern": "\\{jobId\\}" },
          "killSwitchId": { "type": "string", "minLength": 1 },
          "targetWorker": {
            "type": "object",
            "additionalProperties": false,
            "required": ["package", "function"],
            "properties": {
              "package": { "enum": ["research", "publication", "security"] },
              "function": { "type": "string", "minLength": 1 }
            }
          },
          "publicEffect": {
            "enum": ["none", "link-repair-archived-copy", "release-coupled-rebuild"]
          },
          "rosterStatus": { "enum": ["real", "stub"] },
          "implementationOwnerBead": { "type": "string" }
        }
      }
    }
  }
}
