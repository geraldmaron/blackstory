/**
 * Firestore security rules for Black Book (BB-013 / BB-016 / BB-017 / BB-018 / ADR-011).
 *
 * Client boundaries:
 * - Public may read only released public projections and the active release pointer.
 * - Authenticated users may create quarantine submissions; they cannot promote or publish.
 * - Canonical, claims, evidence/provenance, publication, outbox, and operations writes are Admin SDK only.
 * - Trusted staff may append strictly validated user audit events; audit updates/deletes are impossible.
 * - Evidence, sources, captures, lineage, and claim–evidence links are never client-writable.
 * - Research/admin custom claims may read research docs; research cannot publish.
 * - Source adapter kill switches live in killSwitches; enforcement is server-side helpers
 *   (canSourceAdapterCreateCandidates) — clients cannot toggle them.
 *
 * Custom claims (set by privileged backend only):
 * - admin: true | research: true | publication: true | security: true
 * - or bb_role: "admin" | "research" | "publication" | "security"
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function claimTrue(name) {
      return signedIn() && request.auth.token[name] == true;
    }

    function roleIs(name) {
      return signedIn() && request.auth.token.bb_role == name;
    }

    function isAdmin() {
      return claimTrue('admin') || roleIs('admin');
    }

    function isResearch() {
      return claimTrue('research') || roleIs('research') || isAdmin();
    }

    function isPublication() {
      return claimTrue('publication') || roleIs('publication') || isAdmin();
    }

    function isSecurity() {
      return claimTrue('security') || roleIs('security') || isAdmin();
    }

    function submissionCreateValid() {
      return request.resource.data.keys().hasAll(['status', 'createdBy', 'createdAt'])
        && request.resource.data.status == 'quarantined'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'status',
          'createdBy',
          'createdAt',
          'kind',
          'payload',
          'sourceUrl'
        ]);
    }

    function isTrustedAuditWriter() {
      return isAdmin() || isResearch() || isPublication() || isSecurity();
    }

    function auditActionAllowed() {
      let action = request.resource.data.action;
      return isAdmin()
        || (isPublication() && action in [
          'moderation.approved',
          'moderation.rejected',
          'moderation.escalated',
          'publication.published',
          'publication.release_activated',
          'publication.release_retired',
          'correction.requested',
          'correction.applied',
          'retraction.retracted',
          'retraction.reversed'
        ])
        || (isResearch() && action in [
          'source.registered',
          'source.updated',
          'source.enabled',
          'source.disabled',
          'research.created',
          'research.updated',
          'research.completed',
          'moderation.escalated'
        ])
        || (isSecurity() && action in [
          'source.disabled',
          'authentication.signed_in',
          'authentication.failed',
          'authentication.signed_out',
          'authentication.mfa_changed'
        ]);
    }

    function auditEventCreateValid() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'id',
          'action',
          'category',
          'actor',
          'subject',
          'reason',
          'requestId',
          'correlationId',
          'idempotencyKey',
          'occurredAt'
        ])
        && data.keys().hasOnly([
          'id',
          'action',
          'category',
          'actor',
          'subject',
          'reason',
          'requestId',
          'correlationId',
          'releaseId',
          'entityId',
          'idempotencyKey',
          'occurredAt',
          'data'
        ])
        && data.id is string && data.id.size() > 0 && data.id.size() <= 512
        && data.action is string && data.action in [
          'policy.changed',
          'source.registered',
          'source.updated',
          'source.enabled',
          'source.disabled',
          'research.created',
          'research.updated',
          'research.completed',
          'moderation.approved',
          'moderation.rejected',
          'moderation.escalated',
          'publication.published',
          'publication.release_activated',
          'publication.release_retired',
          'correction.requested',
          'correction.applied',
          'retraction.retracted',
          'retraction.reversed',
          'authentication.signed_in',
          'authentication.failed',
          'authentication.signed_out',
          'authentication.mfa_changed',
          'administrative.role_changed',
          'administrative.configuration_changed',
          'administrative.exported'
        ]
        && data.category is string
        && data.category in [
          'policy',
          'source',
          'research',
          'moderation',
          'publication',
          'correction',
          'retraction',
          'authentication',
          'administrative'
        ]
        && data.action.matches('^' + data.category + '\\..+$')
        && data.actor is map
        && data.actor.keys().hasAll(['id', 'type'])
        && data.actor.keys().hasOnly(['id', 'type', 'displayName'])
        && data.actor.id == request.auth.uid
        && data.actor.type == 'user'
        && (!('displayName' in data.actor)
          || (data.actor.displayName is string
            && data.actor.displayName.size() > 0
            && data.actor.displayName.size() <= 256))
        && data.subject is map
        && data.subject.keys().hasAll(['type', 'id', 'path'])
        && data.subject.keys().hasOnly(['type', 'id', 'path'])
        && data.subject.type is string
        && data.subject.type.size() > 0
        && data.subject.type.size() <= 128
        && data.subject.id is string
        && data.subject.id.size() > 0
        && data.subject.id.size() <= 512
        && data.subject.path is string
        && data.subject.path.size() >= 3
        && data.subject.path.size() <= 1500
        && data.reason is string && data.reason.size() > 0 && data.reason.size() <= 2000
        && data.requestId is string && data.requestId.size() > 0 && data.requestId.size() <= 512
        && data.correlationId is string
        && data.correlationId.size() > 0
        && data.correlationId.size() <= 512
        && data.idempotencyKey is string
        && data.idempotencyKey.size() > 0
        && data.idempotencyKey.size() <= 512
        && data.occurredAt is string && data.occurredAt.size() >= 20 && data.occurredAt.size() <= 64
        && (!('releaseId' in data)
          || (data.releaseId is string && data.releaseId.size() > 0 && data.releaseId.size() <= 512))
        && (!('entityId' in data)
          || (data.entityId is string && data.entityId.size() > 0 && data.entityId.size() <= 512))
        && (!('data' in data) || (data.data is map && data.data.keys().size() <= 50));
    }

    match /policy/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /policyVersions/{versionId} {
      allow read: if true;
      allow write: if false;
    }

    match /researchCases/{caseId} {
      allow read: if isResearch();
      allow write: if false;
    }

    match /canonicalEntities/{entityId} {
      allow read, write: if false;

      match /locations/{locationId} {
        allow read, write: if false;
      }
    }

    match /canonicalClaims/{claimId} {
      allow read, write: if false;

      // Versions subcollection (claim-model split: parent doc + immutable version docs).
      // No non-admin principal may write here today either — all claim writes are Admin
      // SDK only per the file header above, and the Admin SDK bypasses these rules
      // entirely — but the create/update/delete split (instead of one `write: if false`)
      // hardcodes the append-only invariant structurally: update/delete stay denied even
      // if a future change ever opens `create` to a client-authenticated write path.
      match /versions/{versionId} {
        allow read: if false;
        allow create: if false;
        allow update, delete: if false;
      }
    }

    // Claim–evidence links (BB-017): Admin SDK only.
    match /claimEvidenceLinks/{linkId} {
      allow read, write: if false;
    }

    match /entityRelationships/{relationshipId} {
      allow read, write: if false;
    }

    match /entityMerges/{mergeId} {
      allow read, write: if false;
    }

    // Evidence / provenance (BB-016): Admin SDK only — never publicly writable.
    match /sourceOrganizations/{organizationId} {
      allow read, write: if false;
    }

    match /sourceDomains/{domainId} {
      allow read, write: if false;
    }

    match /evidenceSources/{sourceId} {
      allow read, write: if false;
    }

    match /sourceItems/{itemId} {
      allow read, write: if false;
    }

    match /sourceCaptures/{captureId} {
      allow read, write: if false;
    }

    match /retrievalEvents/{eventId} {
      allow read, write: if false;
    }

    match /evidenceRecords/{evidenceId} {
      allow read, write: if false;
    }

    match /evidenceLineage/{lineageId} {
      allow read, write: if false;
    }

    match /publicationReleases/{releaseId} {
      allow read: if isPublication();
      allow write: if false;
    }

    match /publicMeta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /publicReleases/{releaseId}/entities/{entityId} {
      // Public list/detail for the web app uses Admin SDK (bypasses rules) or CDN
      // release artifacts (ADR-004). Anonymous client SDK scrapes are denied.
      allow read, write: if false;
    }

    match /publicSearchIndex/{docId} {
      // Search serves from release search-index.json artifacts or Admin SDK reads.
      allow read, write: if false;
    }

    match /submissionInbox/{submissionId} {
      allow create: if signedIn() && submissionCreateValid();
      allow read: if signedIn()
        && (resource.data.createdBy == request.auth.uid || isSecurity() || isAdmin());
      allow update, delete: if false;
    }

    match /auditEvents/{eventId} {
      allow read: if isAdmin() || isSecurity();
      allow create: if isTrustedAuditWriter()
        && request.resource.data.id == eventId
        && auditActionAllowed()
        && auditEventCreateValid();
      allow update, delete: if false;
    }

    match /outboxMessages/{messageId} {
      allow read, write: if false;
    }

    match /idempotencyKeys/{keyId} {
      allow read, write: if false;
    }

    match /outboxConsumerReceipts/{receiptId} {
      allow read, write: if false;
    }

    match /killSwitches/{switchId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Jurisdiction reference data (BB-091): states + counties, public-domain Census-derived.
    // Public read (no PII, no sensitive-site precision — bbox/centroid only); writes are
    // Admin SDK only via the idempotent load/refresh script (packages/firebase/src/
    // jurisdictions/load-cli.ts), same "allow write: if false" convention as every other
    // collection in this file.
    match /jurisdictions/{jurisdictionId} {
      allow read: if true;
      allow write: if false;
    }

    // Census county-decade statistics (black-book-vxz): published federal statistics with
    // required provenance (public-numeric-policy category 3). Public read — no PII, counts
    // as published by the Census Bureau; feeds the county choropleth. Writes are Admin SDK
    // only via packages/firebase/src/demographics/load-cli.ts.
    match /censusCountyDecades/{countyDecadeId} {
      allow read: if true;
      allow write: if false;
    }

    // National decennial race totals 1790–1990 (twps0056, public domain). Same class as
    // censusCountyDecades — published federal statistics with provenance. ~21 tiny docs.
    // Writes via packages/firebase/src/demographics/national-load-cli.ts. The public /data
    // page reads the materialized publicMeta/nationalPopulationTimeline snapshot (Admin SDK),
    // not this collection directly.
    match /censusNationalDecades/{decadeId} {
      allow read: if true;
      allow write: if false;
    }

    // ACS 5-year county estimates: same class as censusCountyDecades (published federal
    // statistics with provenance). Writes via packages/firebase/src/demographics/acs-load-cli.ts.
    match /acsCountyProfiles/{countyVintageId} {
      allow read: if true;
      allow write: if false;
    }

    // ACS 5-year tract estimates: ~85k docs per vintage. Client read stays CLOSED until a
    // server-side aggregation/viewport-bounded surface exists — a public rule here would
    // invite full-collection scans. Admin SDK bypasses rules for the loader and server reads.
    match /acsTractProfiles/{tractVintageId} {
      allow read: if false;
      allow write: if false;
    }

    // Opportunity Atlas curated tract outcomes: attribution-required research data, no
    // public surface yet — CLOSED until one exists with proper attribution treatment.
    // Writes via packages/firebase/scripts/ingest-opportunity-atlas.ts.
    match /opportunityAtlasTracts/{tractId} {
      allow read: if false;
      allow write: if false;
    }

    // HOLC graded areas: DSL vector data is CC BY-NC-SA (see launch-corpora.ts) — HARD
    // rights gate, closed until a rights review clears a specific public treatment.
    // Writes via packages/firebase/scripts/ingest-holc-areas.ts.
    match /holcAreas/{areaId} {
      allow read: if false;
      allow write: if false;
    }

    // FBI UCR agency directory (ORI -> county crosswalk): public-domain reference data, no
    // PII. Writes via packages/firebase/scripts/ingest-hate-crime.ts.
    match /ucrAgencies/{ori} {
      allow read: if true;
      allow write: if false;
    }

    // FBI hate crime county-year aggregates: public-domain published statistics, BUT client
    // read stays CLOSED until a surface exists that renders them beside their coverage
    // caveat. UCR hate crime reporting is voluntary — a county with no document means NO
    // AGENCY REPORTED, never "no hate crime here" (BB-051 no-false-absence; see
    // packages/firebase/src/external/ucr-schema.ts). Publishing these counts bare would
    // read silence as safety, so the gate is the surface, not the data.
    match /hateCrimeCountyYears/{countyYearId} {
      allow read: if false;
      allow write: if false;
    }

    // UCR participation (the coverage denominator): public read — it exists precisely to
    // qualify the counts above and is meaningless as a standalone signal.
    match /ucrStateParticipation/{stateYearId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
