/**
 * Firestore security rules for the raw-ingest named database (blackbook-internal, ADR-012).
 *
 * raw-ingest holds high-volume, bursty research ingestion writes. It is never read or written
 * by any client SDK: research workers write it and the curation step (workers/publication)
 * reads it, both exclusively through the Admin SDK, which bypasses these rules entirely. This
 * deny-all matches the existing pattern used for internal-only collections in the default
 * database's firestore.rules (e.g. canonicalEntities, evidenceRecords, outboxMessages) - there
 * is no end-user-facing surface here to carve an exception for.
 *
 * See docs/adr/ADR-012-production-environment-resplit.md and
 * infra/gcp/terraform/multi-project/iam-cross-project.tf (research_writes_raw_ingest,
 * publication_reads_raw_ingest) for the IAM conditions that scope Admin SDK access instead.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
